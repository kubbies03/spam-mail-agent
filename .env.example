APP_ENV=dev
LOG_LEVEL=INFO

GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-gmail-app-password
GMAIL_FOLDERS=INBOX,[Gmail]/Spam
POLL_INTERVAL_SECONDS=60
MAX_CONCURRENCY=4

DATABASE_URL=sqlite:///data/spam_agent.db
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_TIMEOUT_SECONDS=20

VIRUSTOTAL_API_KEY=
CLASSIFIER_THRESHOLD=0.82
PHISHING_ESCALATION_THRESHOLD=0.50
SPAM_ESCALATION_THRESHOLD=0.65
URL_ANALYSIS_LIMIT=8
VIRUSTOTAL_ENABLED=true
VIRUSTOTAL_DECISIVE_THRESHOLD=0.75
VIRUSTOTAL_COOLDOWN_SECONDS=900
GEMINI_ENABLED=true
GEMINI_COOLDOWN_SECONDS=900
KNOWN_SENDER_DOMAINS=facebookmail.com,linkedin.com,mail.linkedin.com,github.com,notifications.github.com
DISTILBERT_MODEL_DIR=models/distilbert_multilingual
